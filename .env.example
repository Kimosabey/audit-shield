# Copy to .env and adjust. Used by uvicorn / Docker.
# DBeaver / JDBC: see workspace docs/DATABASE_AND_DBEAVER.md (Postgres host port 5433).
PORT=8101

# Required: Postgres with pgvector (see docker-compose.yml)
# postgresql+asyncpg://USER:PASS@HOST:5432/DB
DATABASE_URL=postgresql+asyncpg://audit:audit@127.0.0.1:5433/auditshield

# Required for embeddings, auditor, and synthesis — Ollama must be running and reachable at this URL.
# - Windows/Mac: install Ollama from https://ollama.com and keep the app running (tray icon),
#   OR run: docker compose --profile ollama up -d ollama  (see docker-compose.yml)
# - Then pull models (host shell or: docker compose exec ollama ollama pull …):
#     ollama pull nomic-embed-text
#     ollama pull phi:latest
#     ollama pull llama3.2
# Quick check: curl or browser GET {OLLAMA_BASE_URL}/api/tags — JSON list of models.
# Remote / VPN / Tailscale example:
#   OLLAMA_BASE_URL=http://100.125.103.28:11434
# If the API still logs 127.0.0.1:11434, a Windows user/system env var may be set; this repo loads
# .env with override so the file wins — restart uvicorn after editing .env.
OLLAMA_BASE_URL=http://127.0.0.1:11434

OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_MODEL_AUDITOR=phi:latest

# Default synthesis model when POST /v1/query omits "model"
AUDIT_DEFAULT_MODEL=llama3.2

AUDIT_TOP_K=8
AUDIT_ADMIT_THRESHOLD=0.62
AUDIT_MAX_CHUNK_CHARS=2000

# Comma-separated browser origins for CORS (Vite dev + prod origin)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
