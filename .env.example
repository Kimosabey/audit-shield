# Copy to .env and adjust. Used by uvicorn / Docker.
PORT=8101

# Optional: Ollama base URL (no trailing slash)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Default model when POST /v1/query omits "model"
AUDIT_DEFAULT_MODEL=llama3.2

# Comma-separated browser origins for CORS (Vite dev + prod origin)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Future pipeline hints (not all wired in app/main.py yet):
# OLLAMA_MODEL_AUDITOR=phi:latest
# OLLAMA_MODEL_CHAT=qwen2.5:14b
